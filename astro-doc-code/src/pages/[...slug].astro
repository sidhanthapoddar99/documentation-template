---
/**
 * Dynamic route handler.
 *
 * Delegates the heavy lifting to three helpers under `./lib/`:
 *   - `static-paths.ts` — enumerate every URL at build time
 *   - `route-match.ts`  — resolve the current URL (server mode) + derive
 *                         title / contentType / layoutProps
 *   - `layout-registry.ts` — map `@type/style` aliases to layout loaders
 *
 * This file just wires them together and renders into `BaseLayout`.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { loadSiteConfig } from '@loaders/index';
import { getNavbarLayout, getFooterLayout } from '@loaders/config';
import { buildStaticPaths } from './lib/static-paths';
import {
  matchServerRoute, prepareRender,
  type PageType, type RouteProps,
} from './lib/route-match';
import {
  resolveLayout, resolveChrome, applyLayoutOverride, applyChromeOverride,
  type LayoutVariant,
} from './lib/layout-registry';

export async function getStaticPaths() {
  return buildStaticPaths(loadSiteConfig());
}

// ============================================================================
// Resolve route props — static mode uses Astro.props; server mode walks the
// URL and computes the same shape.
// ============================================================================
let props = Astro.props as Partial<RouteProps>;

if (!props.pageType) {
  const match = await matchServerRoute(loadSiteConfig(), Astro.params.slug || '');
  if (match.kind === 'not-found') return new Response('Not Found', { status: 404 });
  props = match.props;
}
const routeProps = props as RouteProps;

// docs-index: redirect to the first doc (it has no layout of its own).
if (routeProps.pageType === 'docs-index' && routeProps.allContent?.length) {
  return Astro.redirect(`${routeProps.pageConfig.base_url}/${routeProps.allContent[0].slug}`);
}

// ============================================================================
// Dev-toolbar overrides — cookies can swap the page layout / navbar / footer
// without editing `site.yaml`.
// ============================================================================
const isDev = import.meta.env.DEV;
const cookieValue = (name: string): string | null => {
  if (!isDev) return null;
  const v = Astro.cookies.get(name)?.value;
  return v && v !== '__reset__' ? v : null;
};

const effectiveLayout = applyLayoutOverride(routeProps.layout, routeProps.pageType, cookieValue('dev-layout'));
const effectiveNavbar = applyChromeOverride(getNavbarLayout(), 'navbar', cookieValue('dev-navbar'));
const effectiveFooter = applyChromeOverride(getFooterLayout(), 'footer', cookieValue('dev-footer'));

// ============================================================================
// Pick the layout component for this pageType, then build render-time props.
// ============================================================================
const LAYOUT_VARIANT: Partial<Record<PageType, LayoutVariant>> = {
  custom: 'custom',
  docs: 'docs',
  'blog-index': 'blog-index',
  'blog-post': 'blog-post',
  'issues-index': 'issues-index',
  'issues-detail': 'issues-detail',
  'issues-subdoc': 'issues-subdoc',
};

let LayoutComponent: any;
const variant = LAYOUT_VARIANT[routeProps.pageType];
if (variant) {
  LayoutComponent = (await resolveLayout(effectiveLayout, variant, routeProps.pageName)()).default;
}

const NavbarComponent = (await resolveChrome(effectiveNavbar, 'navbar')()).default;
const FooterComponent = (await resolveChrome(effectiveFooter, 'footer')()).default;

const { title, contentType, layoutProps, editorPath } = prepareRender(routeProps);
---

<BaseLayout title={title} contentType={contentType} editorPath={editorPath}>
  <NavbarComponent slot="navbar" />
  <LayoutComponent {...layoutProps} />
  <FooterComponent slot="footer" />
</BaseLayout>
