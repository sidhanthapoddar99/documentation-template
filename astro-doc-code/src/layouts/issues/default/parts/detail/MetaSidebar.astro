---
/**
 * MetaSidebar — right-rail TOC for the overview page.
 *
 * Two panels: overview (issue body link + comment index) and comprehensive
 * (subtasks index). Sub-doc TOCs live on their own pages now (see
 * SubDocMetaSidebar), so no per-subtask / per-note / per-log entries here.
 */
import type { Issue, IssueSubtask } from '@loaders/issues';
import { stateIconSvg } from '../../server/state-icon';
import { pad } from '../../server/helpers';

interface Props {
  issue: Issue;
  sortedSubtasks: IssueSubtask[];
}

const { issue, sortedSubtasks } = Astro.props;
const subtaskTotal = sortedSubtasks.length;
---

<aside class="issue-meta">
  <div class="issue-meta__panel is-active" data-meta-panel="overview">
    <div class="issue-meta-index">
      <div class="issue-meta-index__heading">On this page</div>
      <ul class="issue-meta-toc">
        <li><a href="#" class="issue-meta-toc__link is-top" data-toc-link="__issue_top">Issue body</a></li>
        {issue.comments.length > 0 && (
          <li class="issue-meta-toc__section-label">Comments ({issue.comments.length})</li>
        )}
        {issue.comments.map((c) => (
          <li>
            <a href={`#comment-${c.sequence}`} class="issue-meta-toc__link issue-meta-toc__link--comment" data-toc-link={`comment-${c.sequence}`}>
              <span class="issue-meta-toc__seq">#{String(c.sequence).padStart(3, '0')}</span>
              <span class="issue-meta-toc__text">{c.author || 'unknown'}<span class="issue-meta-toc__date"> · {c.date || '—'}</span></span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  {subtaskTotal > 0 && (
    <div class="issue-meta__panel" data-meta-panel="comprehensive" hidden>
      <div class="issue-meta-index">
        <div class="issue-meta-index__heading">Subtasks index</div>
        <ul class="issue-meta-index__list">
          {sortedSubtasks.map((s) => (
            <li>
              <a
                href={`#comprehensive-${s.slug}`}
                class={`issue-meta-index__link state-${s.state}`}
                data-state={s.state}
                data-subtask-slug={s.slug}
              >
                <span class="issue-meta-index__icon" data-state-icon>
                  <Fragment set:html={stateIconSvg(s.state)} />
                </span>
                {s.sequence !== null && <span class="issue-meta-index__num">{pad(s.sequence)}</span>}
                <span class="issue-meta-index__label">{s.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  )}
</aside>
