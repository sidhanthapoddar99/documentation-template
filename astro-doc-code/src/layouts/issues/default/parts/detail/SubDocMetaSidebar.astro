---
/**
 * SubDocMetaSidebar — right-rail TOC for a standalone sub-doc page.
 *
 * Just the current doc's headings. No panel-swap machinery: this page has
 * exactly one document in the DOM, so the TOC is always active.
 */
import type { TocEntry } from '../../server/toc';

interface Props {
  toc: TocEntry[];
}

const { toc } = Astro.props;
---

<aside class="issue-meta">
  <div class="issue-meta__panel is-active" data-meta-panel="subdoc">
    <div class="issue-meta-index">
      <div class="issue-meta-index__heading">On this page</div>
      {toc.length > 0 ? (
        <ul class="issue-meta-toc">
          {toc.map((h) => (
            <li class={`issue-meta-toc__level-${h.level}`}>
              <a href={`#${h.id}`} class="issue-meta-toc__link" data-toc-link={h.id}>{h.text}</a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="issue-meta-toc__empty">No sections</div>
      )}
    </div>
  </div>
</aside>
