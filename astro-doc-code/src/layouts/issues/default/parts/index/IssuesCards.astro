---
/**
 * IssuesCards - Card view container. Each card row carries the same
 * data-* attributes as the table rows so client.ts can filter/sort both views
 * with one code path.
 */
import IssueCard from '../shared/IssueCard.astro';
import type { Issue, IssuesVocabulary } from '@loaders/issues';

interface Props {
  issues: Issue[];
  vocabulary: IssuesVocabulary;
  baseUrl: string;
  searchBlob: (issue: Issue) => string;
  isOverdue: (meta: Issue['meta']) => boolean;
}

const { issues, vocabulary, baseUrl, searchBlob, isOverdue } = Astro.props;
---

<div class="issues-view issues-view--cards" id="view-cards">
  {issues.map((issue) => (
    <div
      class="issues-view__row"
      data-issue
      data-status={issue.meta.status}
      data-has-review-subtask={issue.subtasks.some((s) => s.state === 'review') ? '1' : '0'}
      data-priority={issue.meta.priority}
      data-component={issue.meta.component.join(' ')}
      data-milestone={issue.meta.milestone}
      data-labels={issue.meta.labels.join(' ')}
      data-assignees={issue.meta.assignees.join(' ')}
      data-updated={issue.meta.updated || ''}
      data-created={issue.created}
      data-due={issue.meta.due || ''}
      data-overdue={isOverdue(issue.meta) ? '1' : '0'}
      data-title={issue.meta.title}
      data-search={searchBlob(issue)}
    >
      <IssueCard issue={issue} href={`${baseUrl}/${issue.id}`} vocabulary={vocabulary} />
    </div>
  ))}
</div>

<style>
  .issues-view { display: none; }
  .issues-view.is-active { display: block; }
  .issues-view--cards { display: none; flex-direction: column; gap: 0.5rem; }
  .issues-view--cards.is-active { display: flex; }

  /* IssueCard uses un-scoped classes (component-level) so these have to be global */
  /* Group section headers (cards view) — colored accent bar */
  :global(.issues-cards__group-header) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 0.9rem 0.65rem;
    margin-top: 1.25rem;
    margin-bottom: 0.25rem;
    border-radius: 8px;
    background: color-mix(in srgb, var(--group-accent, var(--color-brand-primary)) 6%, var(--color-bg-secondary));
    border: 1px solid color-mix(in srgb, var(--group-accent, var(--color-border-default)) 25%, transparent);
  }
  :global(.issues-cards__group-header.is-first) { margin-top: 0; }
  :global(.issues-cards__group-accent) {
    width: 3px;
    height: 16px;
    background: var(--group-accent, var(--color-brand-primary));
    border-radius: 2px;
    flex-shrink: 0;
  }
  :global(.issues-cards__group-field) {
    font-size: var(--ui-text-micro);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  :global(.issues-cards__group-title) {
    font-weight: 600;
    font-size: var(--ui-text-body);
    color: var(--color-text-primary);
    text-transform: capitalize;
  }
  :global(.issues-cards__group-count) {
    margin-left: auto;
    font-family: var(--font-family-mono);
    font-size: var(--ui-text-micro);
    color: color-mix(in srgb, var(--group-accent, var(--color-text-muted)) 85%, var(--color-text-primary));
    padding: 0.1rem 0.5rem;
    border-radius: 10px;
    background: color-mix(in srgb, var(--group-accent, var(--color-border-default)) 18%, transparent);
    border: 1px solid color-mix(in srgb, var(--group-accent, var(--color-border-default)) 30%, transparent);
  }

  :global(.issue-card) {
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    /* Plain background — just a border to separate from the page */
    background: transparent;
    transition: border-color 0.1s ease;
  }
  :global(.issue-card:hover) { border-color: var(--color-border-light); }
  :global(.issue-card__link) {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 0.9rem 1rem;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }
  :global(.issue-card__main) { flex: 1; min-width: 0; }
  :global(.issue-card__title) {
    margin: 0 0 0.25rem;
    font-size: var(--ui-text-body);
    font-weight: var(--font-weight-normal, 400);
    color: var(--color-text-primary);
  }
  :global(.issue-card__description) {
    margin: 0 0 0.5rem;
    color: var(--color-text-muted);
    font-size: var(--ui-text-body);
    line-height: 1.4;
  }
  :global(.issue-card__badges) { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  :global(.issue-card__meta) {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    font-size: var(--ui-text-micro);
    color: var(--color-text-muted);
    font-family: var(--font-family-mono);
    white-space: nowrap;
  }
  :global(.issue-badge) {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 10px;
    font-size: var(--ui-text-micro);
    font-weight: 500;
    line-height: 1.4;
    background: color-mix(in srgb, var(--badge-color, #7aa2f7) 18%, var(--color-bg-primary));
    color: color-mix(in srgb, var(--badge-color, #7aa2f7) 55%, var(--color-text-primary));
    border: 1px solid color-mix(in srgb, var(--badge-color, #7aa2f7) 45%, transparent);
    text-transform: capitalize;
  }
</style>
