# ============================================
# DIRECTORY PATHS
# ============================================
# Bootstrap: points to the config directory containing site.yaml.
# All other paths (data, assets, themes) are defined in site.yaml's paths: section.
CONFIG_DIR=./config

# Optional: External layout directory (mirrors src/layouts/ structure minus BaseLayout).
# External layouts merge with built-in; same-name styles override built-in.
# LAYOUT_EXT_DIR=./layouts

# ============================================
# SERVER SETTINGS
# ============================================

PORT=3088
HOST=true
