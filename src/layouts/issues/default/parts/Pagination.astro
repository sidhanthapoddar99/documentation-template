---
/**
 * Pagination - Per-page selector + prev/next + range display
 * Client-side logic wires up in parts/client.ts.
 */
---

<nav class="issues-pagination" id="issues-pagination" aria-label="Pagination" hidden>
  <div class="issues-pagination__size">
    <label>
      Per page
      <select id="issues-page-size">
        <option value="10">10</option>
        <option value="25">25</option>
        <option value="50">50</option>
        <option value="100">100</option>
      </select>
    </label>
  </div>
  <div class="issues-pagination__range">
    <span id="issues-range">0–0 of 0</span>
  </div>
  <div class="issues-pagination__nav">
    <button type="button" id="issues-prev" class="issues-pagination__btn" disabled aria-label="Previous page">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <span class="issues-pagination__page">
      <span id="issues-page-num">1</span> / <span id="issues-page-total">1</span>
    </span>
    <button type="button" id="issues-next" class="issues-pagination__btn" disabled aria-label="Next page">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>
</nav>

<style>
  .issues-pagination {
    margin-top: 1rem;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: var(--ui-text-body);
    color: var(--color-text-muted);
    background: transparent;
  }
  .issues-pagination__size label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .issues-pagination__size select {
    padding: 0.1rem 0.25rem;
    background: transparent;
    color: inherit;
    border: none;
    border-bottom: 1px solid var(--color-border-default);
    font-size: var(--ui-text-body);
    font-family: inherit;
    cursor: pointer;
  }
  .issues-pagination__size select:hover { border-bottom-color: var(--color-text-muted); }
  .issues-pagination__range { font-family: var(--font-family-mono); }
  .issues-pagination__nav {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .issues-pagination__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    background: transparent;
    color: var(--color-text-primary);
    border: none;
    cursor: pointer;
    border-radius: 3px;
  }
  .issues-pagination__btn:hover:not(:disabled) { color: var(--color-brand-primary); background: var(--color-bg-tertiary); }
  .issues-pagination__btn:disabled {
    color: var(--color-text-muted);
    cursor: not-allowed;
  }
  .issues-pagination__page { font-family: var(--font-family-mono); }
</style>
