---
/**
 * IssuesTable - Table view. Sortable column headers, status/id sub-line in
 * the Title cell, a two-line subtasks cell (count on top, progress bar below),
 * and an overdue-highlighted Due cell.
 *
 * Labels column was intentionally removed — label filter still works from
 * the filter bar, but the column adds visual noise in dense rows.
 */
import StatusBadge from '../shared/StatusBadge.astro';
import type { Issue, IssuesVocabulary } from '@loaders/issues';

interface Props {
  issues: Issue[];
  vocabulary: IssuesVocabulary;
  baseUrl: string;
  searchBlob: (issue: Issue) => string;
  isOverdue: (meta: Issue['meta']) => boolean;
}

const { issues, vocabulary, baseUrl, searchBlob, isOverdue } = Astro.props;

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
function formatDate(value: string | null | undefined): string {
  if (!value) return '';
  const m = /^(\d{4})-(\d{2})-(\d{2})/.exec(value);
  if (!m) return value;
  const [, y, mo, d] = m;
  return `${MONTHS[Number(mo) - 1]} ${Number(d)} ${y}`;
}

const columns = [
  { key: 'component', label: 'Component', sortable: true },
  { key: 'title', label: 'Title', sortable: true, className: 'issues-table__th-title' },
  { key: 'status', label: 'Status', sortable: true },
  { key: 'milestone', label: 'Milestone', sortable: true },
  { key: 'subtasks', label: 'Subtasks', sortable: false },
  { key: 'created', label: 'Created', sortable: true },
  { key: 'due', label: 'Due', sortable: true },
];
---

<div class="issues-view issues-view--table is-active" id="view-table">
  <div class="issues-table-wrap">
    <table class="issues-table" id="issues-table-main" data-issues-table>
      <thead>
        <tr>
          {columns.map((col) => (
            <th class={col.className} data-col={col.key}>
              {col.sortable ? (
                <button type="button" class="issues-table__sort" data-sort={col.key}>
                  <span>{col.label}</span>
                  <span class="issues-table__sort-icon" data-sort-icon={col.key} aria-hidden="true">⇅</span>
                </button>
              ) : (
                <span class="issues-table__label">{col.label}</span>
              )}
            </th>
          ))}
        </tr>
      </thead>
      <tbody id="issues-table-tbody">
        {issues.map((issue) => (
          <tr
            class={`issues-table__row ${isOverdue(issue.meta) ? 'is-overdue' : ''}`}
            data-issue
            data-status={issue.meta.status}
            data-has-review-subtask={issue.subtasks.some((s) => s.state === 'review') ? '1' : '0'}
            data-priority={issue.meta.priority}
            data-component={issue.meta.component}
            data-milestone={issue.meta.milestone}
            data-labels={issue.meta.labels.join(' ')}
            data-updated={issue.meta.updated || ''}
            data-created={issue.created}
            data-due={issue.meta.due || ''}
            data-overdue={isOverdue(issue.meta) ? '1' : '0'}
            data-title={issue.meta.title}
            data-search={searchBlob(issue)}
            data-href={`${baseUrl}/${issue.id}`}
          >
            <td class="issues-table__muted">{issue.meta.component || '—'}</td>
            <td class="issues-table__title-cell">
              <a href={`${baseUrl}/${issue.id}`} class="issues-table__title-link">{issue.meta.title}</a>
              <div class="issues-table__sub">
                <StatusBadge field="priority" value={issue.meta.priority} vocabulary={vocabulary.fields} />
                <span class="issues-table__sub-sep">·</span>
                <span class="issues-table__id">{issue.id}</span>
              </div>
            </td>
            <td><StatusBadge field="status" value={issue.meta.status} vocabulary={vocabulary.fields} /></td>
            <td class="issues-table__muted">{issue.meta.milestone || '—'}</td>
            <td class="issues-table__subtasks-cell">
              {issue.subtasks.length > 0 ? (() => {
                const total = issue.subtasks.length;
                const closed = issue.subtasks.filter((s) => s.state === 'closed').length;
                const cancelled = issue.subtasks.filter((s) => s.state === 'cancelled').length;
                const review = issue.subtasks.filter((s) => s.state === 'review').length;
                const open = total - closed - cancelled - review;
                const done = closed + cancelled;
                const pct = (n: number) => `${(n / total) * 100}%`;
                const tip = `${closed} closed · ${review} review · ${cancelled} cancelled · ${open} open`;
                return (
                  <div class="issues-table__progress" title={tip}>
                    <div class="issues-table__progress-label">{done} / {total} done</div>
                    <div class="issues-table__progress-bar">
                      <div class="issues-table__progress-seg issues-table__progress-seg--closed" style={`width: ${pct(closed)}`}></div>
                      <div class="issues-table__progress-seg issues-table__progress-seg--review" style={`width: ${pct(review)}`}></div>
                      <div class="issues-table__progress-seg issues-table__progress-seg--cancelled" style={`width: ${pct(cancelled)}`}></div>
                    </div>
                  </div>
                );
              })() : (
                <span class="issues-table__muted">—</span>
              )}
            </td>
            <td class="issues-table__date">{formatDate(issue.created) || <span class="issues-table__muted">—</span>}</td>
            <td class={`issues-table__date ${isOverdue(issue.meta) ? 'is-overdue-cell' : ''}`}>
              {formatDate(issue.meta.due) || <span class="issues-table__muted">—</span>}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .issues-view { display: none; }
  .issues-view.is-active { display: block; }

  .issues-table-wrap {
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    /* No overflow container — a scrollable ancestor would trap the sticky
       thead. Transparent bg; the <table> itself owns the solid background. */
    background: transparent;
  }
  .issues-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--ui-text-body);
    background: var(--color-bg-primary);
  }
  /* Hide the Status column when on the Open / Closed tabs — the tab itself
     tells the user the status. The column reappears on the All tab. */
  .issues-table.is-hide-status thead th[data-col='status'],
  .issues-table.is-hide-status tbody td:nth-child(3) {
    display: none;
  }

  /* Group-by: hide the grouped-on column (value is in the section header) */
  .issues-table.is-hide-col-component thead th[data-col='component'],
  .issues-table.is-hide-col-component tbody td:nth-child(1) { display: none; }
  .issues-table.is-hide-col-milestone thead th[data-col='milestone'],
  .issues-table.is-hide-col-milestone tbody td:nth-child(4) { display: none; }
  .issues-table.is-hide-col-priority thead th[data-col='priority'],
  .issues-table.is-hide-col-priority tbody td:nth-child(99) { display: none; }

  /* Grouped view: each group renders as its own standalone <table>, not a
     row injected into the main table. Styles for the grouped UI live in
     styles/groups.css (global sheet) because the group sections are built
     via createElement and don't carry Astro scoped-style attributes. */
  .issues-table thead th {
    text-align: left;
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--color-border-default);
    white-space: nowrap;
    vertical-align: middle;
    /* Sticky relative to the viewport. Offset by the site navbar height so
       the header sits just below the nav when scrolling the page. */
    position: sticky;
    top: var(--navbar-height, 0);
    background: var(--color-bg-primary);
    z-index: 2;
  }
  .issues-table__th-title { min-width: 260px; }
  .issues-table__sort {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: transparent;
    border: none;
    padding: 0;
    color: var(--color-text-muted);
    font-size: var(--ui-text-micro);
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }
  .issues-table__sort:hover { color: inherit; }
  .issues-table__sort-icon { font-size: var(--ui-text-micro); opacity: 0.5; }
  .issues-table__sort-icon.is-active {
    opacity: 1;
    color: var(--color-brand-primary);
  }
  .issues-table__label {
    font-size: var(--ui-text-micro);
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .issues-table td {
    padding: 0.55rem 0.75rem;
    border-top: 1px solid var(--color-border-default);
    vertical-align: middle;
  }
  .issues-table__row {
    cursor: pointer;
    transition: background 0.08s ease;
  }
  /* No row-hover tint. Overdue rows keep their red tint — that's the only
     row color in the table, and it survives hover so the state is obvious. */
  .issues-table__row.is-overdue {
    background: color-mix(in srgb, var(--color-error) 6%, transparent);
  }
  .issues-table__row.is-overdue:hover {
    background: color-mix(in srgb, var(--color-error) 10%, transparent);
  }

  .issues-table__title-cell { line-height: 1.35; }
  .issues-table__title-link {
    display: block; /* force the sub line (status + id) onto the next line always */
    color: inherit;
    text-decoration: none;
    font-weight: var(--font-weight-normal, 400);
  }
  .issues-table__title-link:hover { color: var(--color-brand-primary); }
  .issues-table__sub {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.2rem;
    font-size: var(--ui-text-micro);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }
  .issues-table__sub-sep { opacity: 0.5; }
  .issues-table__id {
    font-family: var(--font-family-mono);
  }
  .issues-table__muted {
    color: var(--color-text-muted);
    text-transform: capitalize;
  }
  .issues-table__date {
    font-family: var(--font-family-mono);
    font-size: var(--ui-text-micro);
    white-space: nowrap;
  }
  .is-overdue-cell { color: var(--color-error) !important; font-weight: 600; }

  /* Two-line subtasks cell */
  .issues-table__subtasks-cell {
    min-width: 90px;
  }
  .issues-table__progress {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .issues-table__progress-label {
    font-family: var(--font-family-mono);
    font-size: var(--ui-text-micro);
    color: var(--color-text-muted);
  }
  .issues-table__progress-bar {
    display: flex;
    width: 100%;
    height: 4px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-border-default) 70%, transparent);
    overflow: hidden;
  }
  .issues-table__progress-seg { height: 100%; }
  .issues-table__progress-seg--closed { background: var(--color-success); }
  .issues-table__progress-seg--review { background: var(--color-warning); }
  .issues-table__progress-seg--cancelled { background: var(--color-error); }
</style>
