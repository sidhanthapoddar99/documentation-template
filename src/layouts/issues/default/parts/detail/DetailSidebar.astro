---
/**
 * DetailSidebar — left-rail nav.
 * Sections: This issue (Overview / Comprehensive) · Notes · Subtasks · Agent log.
 * Click a button → main `<script>` in DetailBody swaps panels; state icons
 * on the Subtasks section cycle on click (handled by scripts/detail/client.ts).
 */
import type { Issue, IssueSubtask } from '@loaders/issues';
import { stateIconSvg } from '../../server/state-icon';
import { pad, TERMINAL, logPanelKey, groupAgentLogs } from '../../server/helpers';

interface Props {
  baseUrl: string;
  issue: Issue;
  sortedSubtasks: IssueSubtask[];
  terminalStartIdx: number;
  subtaskDone: number;
  subtaskReview: number;
}

const { baseUrl, issue, sortedSubtasks, terminalStartIdx, subtaskDone, subtaskReview } = Astro.props;
const subtaskTotal = issue.subtasks.length;

/** Short visible label for an agent-log sidebar entry — drops the
 *  "NNN_" numeric prefix and de-kebabs the rest. */
function logLabel(log: { iteration: number | null; name: string }): string {
  const stem = log.name.replace(/^\d+[_-]/, '').replace(/[-_]/g, ' ');
  return log.iteration !== null ? `#${log.iteration} ${stem}` : stem;
}

const { top: topLogs, bySubgroup: logGroups } = groupAgentLogs(issue.agentLogs);
const logSubgroupNames = Array.from(logGroups.keys()).sort();
---

<aside class="issue-sidebar">
  <a href={baseUrl} class="issue-sidebar__back">
    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="10 4 6 8 10 12"/></svg>
    <span>All issues</span>
  </a>

  <nav class="issue-sidebar__nav">
    <details class="issue-sidebar__section" open>
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>This issue</span>
      </summary>
      <div class="issue-sidebar__items">
        <button type="button" class="issue-sidebar__item is-active" data-panel="overview" aria-current="page">
          <span class="issue-sidebar__label">Overview</span>
          {issue.comments.length > 0 && <span class="issue-sidebar__count">{issue.comments.length}</span>}
        </button>
        {subtaskTotal > 0 && (
          <button type="button" class="issue-sidebar__item" data-panel="comprehensive">
            <span class="issue-sidebar__label">Comprehensive</span>
            <span class="issue-sidebar__count">{subtaskTotal}</span>
          </button>
        )}
      </div>
    </details>

    <details class="issue-sidebar__section" open>
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>Notes</span>
        {issue.notes.length > 0 && <span class="issue-sidebar__heading-count">{issue.notes.length}</span>}
      </summary>
      <div class="issue-sidebar__items">
        {issue.notes.length > 0 ? issue.notes.map((n) => (
          <button type="button" class="issue-sidebar__item" data-panel={`note-${n.name}`}>
            <span class="issue-sidebar__icon" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 1h7l3 3v11H3V1z"/><path d="M10 1v3h3"/>
              </svg>
            </span>
            <span class="issue-sidebar__label">{n.name}.md</span>
          </button>
        )) : (
          <div class="issue-sidebar__empty">No notes</div>
        )}
      </div>
    </details>

    <details class="issue-sidebar__section" open>
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>Subtasks</span>
        {subtaskTotal > 0 && (
          <span class="issue-sidebar__heading-count" id="sidebar-subtasks-count">
            {subtaskDone}/{subtaskTotal}
            {subtaskReview > 0 && <span class="issue-sidebar__review-dot" title={`${subtaskReview} awaiting review`} aria-hidden="true"></span>}
          </span>
        )}
      </summary>
      <div class="issue-sidebar__items">
        {sortedSubtasks.length > 0 ? sortedSubtasks.map((s, idx) => (
          <button
            type="button"
            class={`issue-sidebar__item is-subtask ${TERMINAL.includes(s.state) ? 'is-done' : ''} ${idx === terminalStartIdx && idx > 0 ? 'is-group-start' : ''}`}
            data-panel={`subtask-${s.slug}`}
            data-subtask-slug={s.slug}
            data-state={s.state}
          >
            <span class="issue-sidebar__check" aria-hidden="true" data-state-icon>
              <Fragment set:html={stateIconSvg(s.state)} />
            </span>
            {s.sequence !== null && <span class="issue-sidebar__num">{pad(s.sequence)}</span>}
            <span class="issue-sidebar__label">{s.title}</span>
          </button>
        )) : (
          <div class="issue-sidebar__empty">No subtasks</div>
        )}
      </div>
    </details>

    <details class="issue-sidebar__section">
      <summary class="issue-sidebar__heading">
        <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
        <span>Agent log</span>
        {issue.agentLogs.length > 0 && <span class="issue-sidebar__heading-count">{issue.agentLogs.length}</span>}
      </summary>
      <div class="issue-sidebar__items">
        {issue.agentLogs.length === 0 && (
          <div class="issue-sidebar__empty">No agent-log entries</div>
        )}
        {/* Top-level flat files render first, unindented. */}
        {topLogs.map((log) => (
          <button type="button" class="issue-sidebar__item" data-panel={logPanelKey(log)}>
            <span class="issue-sidebar__icon" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="8" cy="8" r="6"/><path d="M8 4v4l3 2"/>
              </svg>
            </span>
            <span class="issue-sidebar__label">{logLabel(log)}</span>
          </button>
        ))}
        {/* Subgroups as nested collapsible sections, default collapsed. */}
        {logSubgroupNames.map((group) => (
          <details class="issue-sidebar__subgroup">
            <summary class="issue-sidebar__subgroup-heading">
              <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
              <span class="issue-sidebar__subgroup-name">{group}</span>
              <span class="issue-sidebar__heading-count">{logGroups.get(group)!.length}</span>
            </summary>
            <div class="issue-sidebar__items issue-sidebar__items--nested">
              {logGroups.get(group)!.map((log) => (
                <button type="button" class="issue-sidebar__item" data-panel={logPanelKey(log)}>
                  <span class="issue-sidebar__icon" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                      <circle cx="8" cy="8" r="6"/><path d="M8 4v4l3 2"/>
                    </svg>
                  </span>
                  <span class="issue-sidebar__label">{logLabel(log)}</span>
                </button>
              ))}
            </div>
          </details>
        ))}
      </div>
    </details>
  </nav>
</aside>
