---
/**
 * DetailBody — orchestrator for the per-issue detail page.
 *
 * Heavy lifting lives in parts/detail/ (Astro components) and
 * scripts/detail/ (runtime). Shared helpers come from server/.
 *
 * Layout shell is:
 *   [ DetailSidebar ] [ main ] [ MetaSidebar ]
 * main stacks the active panel (overview / comprehensive / subtask-<slug>
 * / note-<name> / log-<name>). panels.ts switches which panel is visible.
 */
import MetaPanel from './parts/shared/MetaPanel.astro';
import DetailSidebar from './parts/detail/DetailSidebar.astro';
import IssueThread from './parts/detail/IssueThread.astro';
import OverviewSubtasks from './parts/detail/OverviewSubtasks.astro';
import Comprehensive from './parts/detail/Comprehensive.astro';
import SubtaskPage from './parts/detail/SubtaskPage.astro';
import NotePage from './parts/detail/NotePage.astro';
import AgentLogPage from './parts/detail/AgentLogPage.astro';
import MetaSidebar from './parts/detail/MetaSidebar.astro';
import { allStateIcons } from './server/state-icon';
import { extractAndPrefixToc } from './server/toc';
import {
  TERMINAL, sortSubtasksForSidebar, terminalStartIndex,
} from './server/helpers';
import type { Issue, IssuesVocabulary } from '@loaders/issues';
import './styles/detail.css';

interface Props {
  issue: Issue;
  vocabulary: IssuesVocabulary;
  baseUrl: string;
}

const { issue, vocabulary, baseUrl } = Astro.props;
const { meta } = issue;

// Tallies for the sidebar + Comprehensive tab counts
const subtaskTotal = issue.subtasks.length;
const subtaskDone = issue.subtasks.filter((s) => TERMINAL.includes(s.state)).length;
const subtaskReview = issue.subtasks.filter((s) => s.state === 'review').length;
const openCount = issue.subtasks.filter((s) => s.state === 'open').length;
const closedCount = issue.subtasks.filter((s) => s.state === 'closed').length;
const cancelledCount = issue.subtasks.filter((s) => s.state === 'cancelled').length;

const sortedSubtasks = sortSubtasksForSidebar(issue.subtasks);
const terminalStartIdx = terminalStartIndex(sortedSubtasks);

const statusColors = vocabulary.fields?.status?.colors || {};

// Pre-process sub-doc HTML: prefix heading IDs so `#<id>` anchors stay
// unambiguous across all the subtask / note / log panels sharing one DOM.
const subtaskDocs = issue.subtasks.map((s) => {
  const { html, toc } = extractAndPrefixToc(s.html, `subtask-${s.slug}`);
  return { ...s, html, toc };
});
const noteDocs = issue.notes.map((n) => {
  const { html, toc } = extractAndPrefixToc(n.html, `note-${n.name}`);
  return { ...n, html, toc };
});
const logDocs = issue.agentLogs.map((log) => {
  const { html, toc } = extractAndPrefixToc(log.html, `log-${log.name}`);
  return { ...log, html, toc };
});
const sortedSubtaskDocs = sortedSubtasks.map(
  (s) => subtaskDocs.find((d) => d.slug === s.slug)!,
);
---

<div class="issue-layout">
  <DetailSidebar
    baseUrl={baseUrl}
    issue={issue}
    sortedSubtasks={sortedSubtasks}
    terminalStartIdx={terminalStartIdx}
    subtaskDone={subtaskDone}
    subtaskReview={subtaskReview}
  />

  <main class="issue-main">
    <header class="issue-main__header">
      <h1 class="issue-main__title">{meta.title}</h1>
      {meta.description && <p class="issue-main__description">{meta.description}</p>}
      <MetaPanel issue={issue} vocabulary={vocabulary} />
    </header>

    <section class="issue-panel is-active" data-panel="overview" role="tabpanel">
      <IssueThread issue={issue} />
      <OverviewSubtasks
        sortedSubtasks={sortedSubtasks}
        subtaskDone={subtaskDone}
        subtaskReview={subtaskReview}
        closedCount={closedCount}
        cancelledCount={cancelledCount}
      />
    </section>

    <Comprehensive
      sortedSubtaskDocs={sortedSubtaskDocs}
      subtaskReview={subtaskReview}
      openCount={openCount}
      closedCount={closedCount}
      cancelledCount={cancelledCount}
      statusColors={statusColors}
    />

    {subtaskDocs.map((s) => <SubtaskPage subtask={s} statusColors={statusColors} />)}
    {noteDocs.map((n) => <NotePage note={n} />)}
    {logDocs.map((log) => <AgentLogPage log={log} />)}
  </main>

  <MetaSidebar
    issue={issue}
    sortedSubtasks={sortedSubtasks}
    subtaskDocs={subtaskDocs}
    noteDocs={noteDocs}
    logDocs={logDocs}
  />
</div>

<!-- Server-rendered state icons for client reuse (state cycling updates these in place) -->
<script is:inline type="application/json" id="subtask-state-icons" set:html={JSON.stringify(allStateIcons())} />

<script>
  import { initIssuesDetail } from './scripts/detail/client';
  initIssuesDetail();
</script>
