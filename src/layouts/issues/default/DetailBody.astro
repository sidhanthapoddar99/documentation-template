---
import MetaPanel from './MetaPanel.astro';
import type { Issue, IssuesVocabulary } from '@loaders/issues';

interface Props {
  issue: Issue;
  vocabulary: IssuesVocabulary;
  baseUrl: string;
}

const { issue, vocabulary, baseUrl } = Astro.props;
const { meta } = issue;

// Deterministic color per author — stable hash into a small palette
const AVATAR_COLORS = ['#7aa2f7', '#bb9af7', '#f7768e', '#e0af68', '#9ece6a', '#2ac3de', '#ff9e64'];
function avatarColor(name: string | null | undefined): string {
  if (!name) return AVATAR_COLORS[0];
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) >>> 0;
  return AVATAR_COLORS[h % AVATAR_COLORS.length];
}
function initial(name: string | null | undefined): string {
  return (name || '?').trim().charAt(0).toUpperCase();
}
---

<article class="issue-detail">
  <div class="issue-detail__container">
    <a href={baseUrl} class="issue-detail__back">← Back to issues</a>

    <header class="issue-detail__header">
      <div class="issue-detail__id">{issue.id}</div>
      <h1 class="issue-detail__title">{meta.title}</h1>
      {meta.description && <p class="issue-detail__description">{meta.description}</p>}
    </header>

    <div class="issue-detail__layout">
      <!-- Left sidebar: Overview + supporting files -->
      <aside class="issue-filenav">
        <div class="issue-filenav__group">
          <div class="issue-filenav__heading">This issue</div>
          <button
            type="button"
            class="issue-filenav__item is-active"
            data-file="overview"
            aria-current="page"
          >
            <span class="issue-filenav__icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 2h9l3 3v9H2V2z"/><path d="M11 2v3h3"/>
              </svg>
            </span>
            <span class="issue-filenav__label">Overview</span>
            {issue.comments.length > 0 && <span class="issue-filenav__count">{issue.comments.length}</span>}
          </button>
        </div>

        {issue.supportingDocs.length > 0 && (
          <div class="issue-filenav__group">
            <div class="issue-filenav__heading">Files</div>
            {issue.supportingDocs.map((d) => (
              <button
                type="button"
                class="issue-filenav__item"
                data-file={`doc-${d.name}`}
              >
                <span class="issue-filenav__icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M3 1h7l3 3v11H3V1z"/><path d="M10 1v3h3"/>
                  </svg>
                </span>
                <span class="issue-filenav__label">{d.name}.md</span>
              </button>
            ))}
          </div>
        )}
      </aside>

      <!-- Main content panels -->
      <div class="issue-detail__main">
        <!-- Overview: issue body + GitHub-style comments thread -->
        <section class="issue-panel is-active" data-panel="overview" role="tabpanel">
          <div class="issue-thread">
            <!-- Initial comment = issue body -->
            <div class="issue-thread__item">
              <div class="issue-thread__avatar" style={`background: ${avatarColor(meta.author)}`}>
                {initial(meta.author)}
              </div>
              <div class="issue-thread__bubble">
                <div class="issue-thread__bubble-header">
                  <span class="issue-thread__author">{meta.author || 'unknown'}</span>
                  <span class="issue-thread__action">opened this issue</span>
                  <span class="issue-thread__date">on {issue.created}</span>
                </div>
                <div class="issue-thread__bubble-body markdown-content">
                  <Fragment set:html={issue.html} />
                </div>
              </div>
            </div>

            <!-- Each comment -->
            {issue.comments.map((c) => (
              <div class="issue-thread__item">
                <div class="issue-thread__avatar" style={`background: ${avatarColor(c.author)}`}>
                  {initial(c.author)}
                </div>
                <div class="issue-thread__bubble">
                  <div class="issue-thread__bubble-header">
                    <span class="issue-thread__author">{c.author || 'unknown'}</span>
                    <span class="issue-thread__action">commented</span>
                    <span class="issue-thread__date">on {c.date || '—'}</span>
                    <span class="issue-thread__seq">#{String(c.sequence).padStart(3, '0')}</span>
                  </div>
                  <div class="issue-thread__bubble-body markdown-content">
                    <Fragment set:html={c.html} />
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Supporting docs: plain markdown, no comment styling -->
        {issue.supportingDocs.map((d) => (
          <section class="issue-panel" data-panel={`doc-${d.name}`} role="tabpanel" hidden>
            <div class="issue-doc">
              <div class="issue-doc__path">{d.name}.md</div>
              <div class="issue-doc__body markdown-content">
                <Fragment set:html={d.html} />
              </div>
            </div>
          </section>
        ))}
      </div>

      <!-- Right sidebar: metadata -->
      <div class="issue-detail__meta">
        <MetaPanel issue={issue} vocabulary={vocabulary} />
      </div>
    </div>
  </div>
</article>

<script>
  const filenav = document.querySelector<HTMLElement>('.issue-filenav');
  filenav?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-file]') as HTMLElement | null;
    if (!btn) return;
    const key = btn.dataset.file!;
    filenav.querySelectorAll<HTMLElement>('.issue-filenav__item').forEach((b) => {
      const active = b.dataset.file === key;
      b.classList.toggle('is-active', active);
      if (active) b.setAttribute('aria-current', 'page');
      else b.removeAttribute('aria-current');
    });
    document.querySelectorAll<HTMLElement>('.issue-panel').forEach((p) => {
      const match = p.dataset.panel === key;
      p.classList.toggle('is-active', match);
      if (match) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
  });
</script>

<style>
  .issue-detail {
    padding: 2rem 1.5rem;
  }
  .issue-detail__container {
    max-width: 1300px;
    margin: 0 auto;
  }
  .issue-detail__back {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-text-muted, #888);
    text-decoration: none;
    font-size: 0.85rem;
  }
  .issue-detail__back:hover {
    color: inherit;
  }
  .issue-detail__id {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--color-text-muted, #888);
  }
  .issue-detail__title {
    margin: 0.25rem 0 0.5rem;
    font-size: 1.75rem;
  }
  .issue-detail__description {
    margin: 0 0 2rem;
    color: var(--color-text-muted, #888);
  }
  .issue-detail__layout {
    display: grid;
    grid-template-columns: 200px 1fr 280px;
    gap: 1.5rem;
    align-items: start;
  }
  .issue-detail__meta {
    position: sticky;
    top: 1rem;
  }

  /* Left sidebar: file nav */
  .issue-filenav {
    position: sticky;
    top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .issue-filenav__group {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .issue-filenav__heading {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted, #888);
    padding: 0 0.5rem;
    margin-bottom: 0.35rem;
  }
  .issue-filenav__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4rem 0.5rem;
    background: transparent;
    border: none;
    border-radius: 4px;
    color: var(--color-text-muted, #888);
    font-size: 0.85rem;
    cursor: pointer;
    text-align: left;
    transition: background 0.08s ease;
  }
  .issue-filenav__item:hover {
    background: color-mix(in srgb, var(--color-border, #2a2a2a) 40%, transparent);
    color: inherit;
  }
  .issue-filenav__item.is-active {
    background: color-mix(in srgb, var(--color-accent, #7aa2f7) 15%, transparent);
    color: var(--color-accent, #7aa2f7);
  }
  .issue-filenav__icon {
    display: inline-flex;
    flex-shrink: 0;
  }
  .issue-filenav__label {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .issue-filenav__count {
    background: var(--color-border, #2a2a2a);
    color: var(--color-text-muted, #888);
    border-radius: 10px;
    padding: 0 0.4rem;
    font-size: 0.65rem;
    line-height: 1.5;
    font-family: var(--font-mono, monospace);
  }

  /* Overview thread (GitHub-style comments) */
  .issue-thread {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }
  .issue-thread::before {
    content: '';
    position: absolute;
    left: 19px;
    top: 40px;
    bottom: 20px;
    width: 2px;
    background: var(--color-border, #2a2a2a);
    z-index: 0;
  }
  .issue-thread__item {
    display: flex;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }
  .issue-thread__avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    font-family: var(--font-sans, system-ui);
    border: 2px solid var(--color-bg, #111);
  }
  .issue-thread__bubble {
    flex: 1;
    min-width: 0;
    border: 1px solid var(--color-border, #2a2a2a);
    border-radius: 6px;
    background: var(--color-surface, transparent);
    overflow: hidden;
    position: relative;
  }
  .issue-thread__bubble::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 14px;
    width: 0;
    height: 0;
    border-top: 7px solid transparent;
    border-bottom: 7px solid transparent;
    border-right: 8px solid var(--color-border, #2a2a2a);
  }
  .issue-thread__bubble::after {
    content: '';
    position: absolute;
    left: -7px;
    top: 15px;
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-right: 7px solid var(--color-surface, #111);
  }
  .issue-thread__bubble-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    background: color-mix(in srgb, var(--color-border, #2a2a2a) 30%, transparent);
    border-bottom: 1px solid var(--color-border, #2a2a2a);
    font-size: 0.8rem;
    color: var(--color-text-muted, #888);
    flex-wrap: wrap;
  }
  .issue-thread__author {
    font-weight: 600;
    color: inherit;
  }
  .issue-thread__date {
    color: var(--color-text-muted, #888);
  }
  .issue-thread__seq {
    margin-left: auto;
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    color: var(--color-text-muted, #888);
  }
  .issue-thread__bubble-body {
    padding: 1rem;
  }
  .issue-thread__bubble-body :global(p:first-child) {
    margin-top: 0;
  }
  .issue-thread__bubble-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Supporting doc panel — plain markdown */
  .issue-doc {
    border: 1px solid var(--color-border, #2a2a2a);
    border-radius: 6px;
    padding: 1.5rem;
    background: var(--color-surface, transparent);
  }
  .issue-doc__path {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--color-text-muted, #888);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border, #2a2a2a);
  }
  .issue-doc__body :global(p:first-child),
  .issue-doc__body :global(h1:first-child),
  .issue-doc__body :global(h2:first-child),
  .issue-doc__body :global(h3:first-child) {
    margin-top: 0;
  }

  @media (max-width: 1100px) {
    .issue-detail__layout {
      grid-template-columns: 180px 1fr;
    }
    .issue-detail__meta {
      grid-column: 1 / -1;
      position: static;
    }
  }
  @media (max-width: 700px) {
    .issue-detail__layout {
      grid-template-columns: 1fr;
    }
    .issue-filenav {
      position: static;
      flex-direction: row;
      overflow-x: auto;
      gap: 1.5rem;
    }
    .issue-filenav__group {
      flex-direction: row;
      gap: 0.25rem;
      align-items: center;
    }
    .issue-filenav__heading {
      margin: 0;
    }
    .issue-thread::before {
      display: none;
    }
  }
</style>
