---
import MetaPanel from './MetaPanel.astro';
import type { Issue, IssuesVocabulary, SubtaskState } from '@loaders/issues';

interface Props {
  issue: Issue;
  vocabulary: IssuesVocabulary;
  baseUrl: string;
}

const { issue, vocabulary, baseUrl } = Astro.props;
const { meta } = issue;

const AVATAR_COLORS = ['#7aa2f7', '#bb9af7', '#f7768e', '#e0af68', '#9ece6a', '#2ac3de', '#ff9e64'];
function avatarColor(name: string | null | undefined): string {
  if (!name) return AVATAR_COLORS[0];
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) >>> 0;
  return AVATAR_COLORS[h % AVATAR_COLORS.length];
}
function initial(name: string | null | undefined): string {
  return (name || '?').trim().charAt(0).toUpperCase();
}
function pad(n: number | null): string {
  if (n === null) return '';
  return String(n).padStart(2, '0');
}

// SVG for the 4-state icon. Kept server-side so client can swap in place
// when a subtask's state cycles without re-rendering the whole layout.
// Subtask bodies in the Comprehensive panel collapse past 150 words so the
// list stays scannable. Word count ignores HTML tags / entities.
const COMPREHENSIVE_WORD_CAP = 150;
function wordCount(html: string): number {
  if (!html) return 0;
  const text = html.replace(/<[^>]*>/g, ' ').replace(/&[#a-z0-9]+;/gi, ' ');
  const words = text.trim().split(/\s+/).filter(Boolean);
  return words.length;
}

function stateIconSvg(state: SubtaskState): string {
  switch (state) {
    case 'open':
      return '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/></svg>';
    case 'review':
      return '<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="4"/></svg>';
    case 'closed':
      return '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3 3 7-7"/></svg>';
    case 'cancelled':
      return '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8"/></svg>';
  }
}

const TERMINAL: SubtaskState[] = ['closed', 'cancelled'];
const subtaskDone = issue.subtasks.filter((s) => TERMINAL.includes(s.state)).length;
const subtaskReview = issue.subtasks.filter((s) => s.state === 'review').length;
const subtaskTotal = issue.subtasks.length;
const openCount = issue.subtasks.filter((s) => s.state === 'open').length;
const closedCount = issue.subtasks.filter((s) => s.state === 'closed').length;
const cancelledCount = issue.subtasks.filter((s) => s.state === 'cancelled').length;

// Sort sidebar subtasks:
//   1. Active group (open | review) first, terminal group (closed | cancelled) after
//   2. Within each group, by numeric prefix ascending (preserves sequence)
const STATE_GROUP: Record<SubtaskState, number> = { open: 0, review: 0, closed: 1, cancelled: 1 };
const sortedSubtasks = [...issue.subtasks].sort((a, b) => {
  const g = STATE_GROUP[a.state] - STATE_GROUP[b.state];
  if (g !== 0) return g;
  const sa = a.sequence ?? Number.MAX_SAFE_INTEGER;
  const sb = b.sequence ?? Number.MAX_SAFE_INTEGER;
  return sa - sb;
});
const terminalStartIdx = sortedSubtasks.findIndex((s) => TERMINAL.includes(s.state));

const statusColors = vocabulary.fields?.status?.colors || {};
---

<div class="issue-layout">
  <!-- Left sidebar -->
  <aside class="issue-sidebar">
    <a href={baseUrl} class="issue-sidebar__back">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="10 4 6 8 10 12"/></svg>
      <span>All issues</span>
    </a>

    <nav class="issue-sidebar__nav">
      <!-- This issue -->
      <details class="issue-sidebar__section" open>
        <summary class="issue-sidebar__heading">
          <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
          <span>This issue</span>
        </summary>
        <div class="issue-sidebar__items">
          <button type="button" class="issue-sidebar__item is-active" data-panel="overview" aria-current="page">
            <span class="issue-sidebar__label">Overview</span>
            {issue.comments.length > 0 && <span class="issue-sidebar__count">{issue.comments.length}</span>}
          </button>
          {subtaskTotal > 0 && (
            <button type="button" class="issue-sidebar__item" data-panel="comprehensive">
              <span class="issue-sidebar__label">Comprehensive</span>
              <span class="issue-sidebar__count">{subtaskTotal}</span>
            </button>
          )}
        </div>
      </details>

      <!-- Notes -->
      <details class="issue-sidebar__section" open>
        <summary class="issue-sidebar__heading">
          <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
          <span>Notes</span>
          {issue.notes.length > 0 && <span class="issue-sidebar__heading-count">{issue.notes.length}</span>}
        </summary>
        <div class="issue-sidebar__items">
          {issue.notes.length > 0 ? issue.notes.map((n) => (
            <button type="button" class="issue-sidebar__item" data-panel={`note-${n.name}`}>
              <span class="issue-sidebar__icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 1h7l3 3v11H3V1z"/><path d="M10 1v3h3"/>
                </svg>
              </span>
              <span class="issue-sidebar__label">{n.name}.md</span>
            </button>
          )) : (
            <div class="issue-sidebar__empty">No notes</div>
          )}
        </div>
      </details>

      <!-- Subtasks -->
      <details class="issue-sidebar__section" open>
        <summary class="issue-sidebar__heading">
          <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
          <span>Subtasks</span>
          {subtaskTotal > 0 && (
            <span class="issue-sidebar__heading-count" id="sidebar-subtasks-count">
              {subtaskDone}/{subtaskTotal}
              {subtaskReview > 0 && <span class="issue-sidebar__review-dot" title={`${subtaskReview} awaiting review`} aria-hidden="true"></span>}
            </span>
          )}
        </summary>
        <div class="issue-sidebar__items">
          {sortedSubtasks.length > 0 ? sortedSubtasks.map((s, idx) => (
            <button
              type="button"
              class={`issue-sidebar__item is-subtask ${TERMINAL.includes(s.state) ? 'is-done' : ''} ${idx === terminalStartIdx && idx > 0 ? 'is-group-start' : ''}`}
              data-panel={`subtask-${s.slug}`}
              data-subtask-slug={s.slug}
              data-state={s.state}
            >
              <span class="issue-sidebar__check" aria-hidden="true" data-state-icon>
                <Fragment set:html={stateIconSvg(s.state)} />
              </span>
              {s.sequence !== null && <span class="issue-sidebar__num">{pad(s.sequence)}</span>}
              <span class="issue-sidebar__label">{s.title}</span>
            </button>
          )) : (
            <div class="issue-sidebar__empty">No subtasks</div>
          )}
        </div>
      </details>

      <!-- Agent log -->
      <details class="issue-sidebar__section">
        <summary class="issue-sidebar__heading">
          <svg class="issue-sidebar__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3l3 3 3-3"/></svg>
          <span>Agent log</span>
          {issue.agentLogs.length > 0 && <span class="issue-sidebar__heading-count">{issue.agentLogs.length}</span>}
        </summary>
        <div class="issue-sidebar__items">
          {issue.agentLogs.length > 0 ? issue.agentLogs.map((log) => (
            <button type="button" class="issue-sidebar__item" data-panel={`log-${log.name}`}>
              <span class="issue-sidebar__icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="8" cy="8" r="6"/><path d="M8 4v4l3 2"/>
                </svg>
              </span>
              <span class="issue-sidebar__label">
                {log.iteration !== null ? `#${log.iteration} ` : ''}{log.name.replace(/^\d+[_-]/, '').replace(/[-_]/g, ' ')}
              </span>
            </button>
          )) : (
            <div class="issue-sidebar__empty">No agent-log entries</div>
          )}
        </div>
      </details>
    </nav>
  </aside>

  <!-- Main content -->
  <main class="issue-main">
    <header class="issue-main__header">
      <h1 class="issue-main__title">{meta.title}</h1>
      {meta.description && <p class="issue-main__description">{meta.description}</p>}
    </header>

    <!-- Overview: issue body + comment thread + flat subtask list -->
    <section class="issue-panel is-active" data-panel="overview" role="tabpanel">
      <div class="issue-thread">
        <div class="issue-thread__item">
          <div class="issue-thread__avatar" style={`background: ${avatarColor(meta.author)}`}>
            {initial(meta.author)}
          </div>
          <div class="issue-thread__bubble">
            <div class="issue-thread__bubble-header">
              <span class="issue-thread__author">{meta.author || 'unknown'}</span>
              <span class="issue-thread__action">opened this issue</span>
              <span class="issue-thread__date">on {issue.created}</span>
            </div>
            <div class="issue-thread__bubble-body markdown-content">
              <Fragment set:html={issue.html} />
            </div>
          </div>
        </div>

        {issue.comments.map((c) => (
          <div class="issue-thread__item">
            <div class="issue-thread__avatar" style={`background: ${avatarColor(c.author)}`}>
              {initial(c.author)}
            </div>
            <div class="issue-thread__bubble">
              <div class="issue-thread__bubble-header">
                <span class="issue-thread__author">{c.author || 'unknown'}</span>
                <span class="issue-thread__action">commented</span>
                <span class="issue-thread__date">on {c.date || '—'}</span>
                <span class="issue-thread__seq">#{String(c.sequence).padStart(3, '0')}</span>
              </div>
              <div class="issue-thread__bubble-body markdown-content">
                <Fragment set:html={c.html} />
              </div>
            </div>
          </div>
        ))}
      </div>

      {sortedSubtasks.length > 0 && (
        <section class="issue-overview-subtasks" aria-label="Subtasks">
          <div class="issue-overview-subtasks__header">
            <span class="issue-overview-subtasks__title">Subtasks</span>
            <span class="issue-overview-subtasks__count" id="overview-subtasks-count">{subtaskDone} / {subtaskTotal}</span>
            <div class="issue-overview-subtasks__bar" aria-hidden="true" id="overview-subtasks-bar">
              <div class="issue-overview-subtasks__seg issue-overview-subtasks__seg--closed" style={`width: ${subtaskTotal ? (closedCount / subtaskTotal) * 100 : 0}%`}></div>
              <div class="issue-overview-subtasks__seg issue-overview-subtasks__seg--cancelled" style={`width: ${subtaskTotal ? (cancelledCount / subtaskTotal) * 100 : 0}%`}></div>
              <div class="issue-overview-subtasks__seg issue-overview-subtasks__seg--review" style={`width: ${subtaskTotal ? (subtaskReview / subtaskTotal) * 100 : 0}%`}></div>
            </div>
          </div>
          <ul class="issue-overview-subtasks__list">
            {sortedSubtasks.map((s) => (
              <li
                class={`issue-overview-subtasks__item state-${s.state}`}
                data-subtask-slug={s.slug}
                data-file={s.filePath}
                data-state={s.state}
              >
                <button
                  type="button"
                  class="issue-overview-subtasks__state"
                  aria-label={`Subtask state: ${s.state}. Click to cycle.`}
                  data-state={s.state}
                >
                  <Fragment set:html={stateIconSvg(s.state)} />
                </button>
                {s.sequence !== null && <span class="issue-overview-subtasks__num">{pad(s.sequence)}</span>}
                <a href={`#subtask-${s.slug}`} class="issue-overview-subtasks__link">{s.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </section>

    <!-- Comprehensive: 4-state filter tabs + all subtask bodies inline -->
    {subtaskTotal > 0 && (
      <section class="issue-panel" data-panel="comprehensive" role="tabpanel" hidden>
        <div class="issue-comprehensive">
          <div class="issue-comprehensive__tabs" role="tablist">
            <button type="button" class="issue-comprehensive__tab is-active" data-comprehensive-tab="review">
              Review <span class="issue-comprehensive__tab-count">{subtaskReview}</span>
            </button>
            <button type="button" class="issue-comprehensive__tab" data-comprehensive-tab="open">
              Open <span class="issue-comprehensive__tab-count">{openCount}</span>
            </button>
            <button type="button" class="issue-comprehensive__tab" data-comprehensive-tab="closed">
              Closed <span class="issue-comprehensive__tab-count">{closedCount}</span>
            </button>
            <button type="button" class="issue-comprehensive__tab" data-comprehensive-tab="cancelled">
              Cancelled <span class="issue-comprehensive__tab-count">{cancelledCount}</span>
            </button>
            <button type="button" class="issue-comprehensive__tab" data-comprehensive-tab="all">
              All <span class="issue-comprehensive__tab-count">{subtaskTotal}</span>
            </button>
          </div>

          <ul class="issue-comprehensive__list">
            {sortedSubtasks.map((s) => {
              const words = wordCount(s.html);
              const clippable = words > COMPREHENSIVE_WORD_CAP;
              return (
                <li
                  class={`issue-comprehensive__item state-${s.state} ${clippable ? 'is-clipped' : ''}`}
                  data-subtask-slug={s.slug}
                  data-file={s.filePath}
                  data-state={s.state}
                  data-clippable={clippable ? 'true' : undefined}
                  id={`comprehensive-${s.slug}`}
                >
                  <div class="issue-comprehensive__item-head">
                    <button
                      type="button"
                      class="issue-comprehensive__state"
                      aria-label={`Subtask state: ${s.state}. Click to cycle.`}
                      data-state={s.state}
                    >
                      <Fragment set:html={stateIconSvg(s.state)} />
                    </button>
                    {s.sequence !== null && <span class="issue-comprehensive__num">{pad(s.sequence)}</span>}
                    <span class="issue-comprehensive__title">{s.title}</span>
                    <span class="issue-comprehensive__pill" data-state-pill style={statusColors[s.state] ? `--badge-color: ${statusColors[s.state]}` : undefined}>
                      {s.state}
                    </span>
                  </div>
                  {s.html && (
                    <div class="issue-comprehensive__body markdown-content">
                      <Fragment set:html={s.html} />
                    </div>
                  )}
                  {clippable && (
                    <div class="issue-comprehensive__expand-row">
                      <span class="issue-comprehensive__word-count">{words} words</span>
                      <button
                        type="button"
                        class="issue-comprehensive__expand"
                        data-comprehensive-expand
                        aria-expanded="false"
                        aria-label="Expand subtask"
                      >
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 6 8 10 12 6"/></svg>
                      </button>
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    )}

    <!-- Subtask pages -->
    {issue.subtasks.map((s) => (
      <section class="issue-panel" data-panel={`subtask-${s.slug}`} role="tabpanel" hidden>
        <div class="issue-doc">
          <div class="issue-doc__path">subtasks/{s.slug}.md</div>
          <div class="issue-subtask-page" data-subtask-slug={s.slug} data-file={s.filePath} data-state={s.state}>
            <div class="issue-subtask-page__header">
              {s.sequence !== null && <span class="issue-subtask-page__num">{pad(s.sequence)}</span>}
              <span class="issue-subtask-page__title">{s.title}</span>
              <span class="issue-subtask-page__badge" data-state-pill style={statusColors[s.state] ? `--badge-color: ${statusColors[s.state]}` : undefined}>
                {s.state}
              </span>
            </div>
            {s.html && (
              <div class="issue-subtask-page__body markdown-content">
                <Fragment set:html={s.html} />
              </div>
            )}
          </div>
        </div>
      </section>
    ))}

    <!-- Note pages -->
    {issue.notes.map((n) => (
      <section class="issue-panel" data-panel={`note-${n.name}`} role="tabpanel" hidden>
        <div class="issue-doc">
          <div class="issue-doc__path">notes/{n.name}.md</div>
          <div class="issue-doc__body markdown-content">
            <Fragment set:html={n.html} />
          </div>
        </div>
      </section>
    ))}

    <!-- Agent-log pages -->
    {issue.agentLogs.map((log) => (
      <section class="issue-panel" data-panel={`log-${log.name}`} role="tabpanel" hidden>
        <div class="issue-doc">
          <div class="issue-log__header">
            <span class="issue-doc__path">agent-log/{log.name}.md</span>
            <div class="issue-log__meta">
              {log.iteration !== null && <span class="issue-log__chip">iter {log.iteration}</span>}
              {log.agent && <span class="issue-log__chip">{log.agent}</span>}
              {log.status && <span class={`issue-log__chip issue-log__chip--status is-${log.status.replace(/\s+/g, '-')}`}>{log.status}</span>}
              {log.date && <span class="issue-log__chip">{log.date}</span>}
            </div>
          </div>
          <div class="issue-doc__body markdown-content">
            <Fragment set:html={log.html} />
          </div>
        </div>
      </section>
    ))}
  </main>

  <!-- Right sidebar — default = MetaPanel, swapped to subtask index on Comprehensive -->
  <aside class="issue-meta">
    <div class="issue-meta__panel is-active" data-meta-panel="default">
      <MetaPanel issue={issue} vocabulary={vocabulary} />
    </div>
    {subtaskTotal > 0 && (
      <div class="issue-meta__panel" data-meta-panel="comprehensive" hidden>
        <div class="issue-meta-index">
          <div class="issue-meta-index__heading">Subtasks index</div>
          <ul class="issue-meta-index__list">
            {sortedSubtasks.map((s) => (
              <li>
                <a
                  href={`#comprehensive-${s.slug}`}
                  class={`issue-meta-index__link state-${s.state}`}
                  data-state={s.state}
                  data-subtask-slug={s.slug}
                >
                  <span class="issue-meta-index__icon" data-state-icon>
                    <Fragment set:html={stateIconSvg(s.state)} />
                  </span>
                  {s.sequence !== null && <span class="issue-meta-index__num">{pad(s.sequence)}</span>}
                  <span class="issue-meta-index__label">{s.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
  </aside>
</div>

<!-- Server-rendered state icons for client reuse -->
<script is:inline type="application/json" id="subtask-state-icons" set:html={JSON.stringify({
  open: stateIconSvg('open'),
  review: stateIconSvg('review'),
  closed: stateIconSvg('closed'),
  cancelled: stateIconSvg('cancelled'),
})} />

<script>
  const sidebar = document.querySelector<HTMLElement>('.issue-sidebar');
  type SubtaskState = 'open' | 'review' | 'closed' | 'cancelled';
  const CYCLE: SubtaskState[] = ['open', 'review', 'closed', 'cancelled'];
  const TERMINAL: SubtaskState[] = ['closed', 'cancelled'];

  const iconEl = document.getElementById('subtask-state-icons');
  const ICONS: Record<SubtaskState, string> = iconEl?.textContent
    ? JSON.parse(iconEl.textContent)
    : { open: '', review: '', closed: '', cancelled: '' };

  function knownPanel(key: string): boolean {
    return !!document.querySelector(`.issue-panel[data-panel="${CSS.escape(key)}"]`);
  }

  function expandSectionFor(panelKey: string) {
    const btn = sidebar?.querySelector<HTMLElement>(`.issue-sidebar__item[data-panel="${CSS.escape(panelKey)}"]`);
    const section = btn?.closest<HTMLDetailsElement>('details.issue-sidebar__section');
    if (section && !section.open) section.open = true;
  }

  function activate(panelKey: string, opts: { updateHash?: boolean } = {}) {
    sidebar?.querySelectorAll<HTMLElement>('.issue-sidebar__item').forEach((b) => {
      const active = b.dataset.panel === panelKey;
      b.classList.toggle('is-active', active);
      if (active) b.setAttribute('aria-current', 'page');
      else b.removeAttribute('aria-current');
    });
    document.querySelectorAll<HTMLElement>('.issue-panel').forEach((p) => {
      const match = p.dataset.panel === panelKey;
      p.classList.toggle('is-active', match);
      if (match) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
    // Swap right sidebar content: Comprehensive → subtask index, else → MetaPanel
    const metaPanelKey = panelKey === 'comprehensive' ? 'comprehensive' : 'default';
    document.querySelectorAll<HTMLElement>('.issue-meta__panel').forEach((p) => {
      const match = p.dataset.metaPanel === metaPanelKey;
      p.classList.toggle('is-active', match);
      if (match) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
    expandSectionFor(panelKey);
    if (opts.updateHash !== false) {
      const desired = panelKey === 'overview' ? ' ' : `#${panelKey}`;
      if (desired === ' ') history.replaceState(null, '', location.pathname + location.search);
      else history.replaceState(null, '', desired);
    }
  }

  sidebar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-panel]');
    if (!btn) return;
    activate(btn.dataset.panel!);
  });

  // Initial panel from #hash (if present and valid). Deep-link support:
  // a hash like `#comprehensive-<slug>` activates Comprehensive and scrolls to the item.
  const rawHash = decodeURIComponent(location.hash.slice(1));
  if (rawHash) {
    if (rawHash.startsWith('comprehensive-')) {
      activate('comprehensive', { updateHash: false });
      requestAnimationFrame(() => {
        document.getElementById(rawHash)?.scrollIntoView({ block: 'start' });
      });
    } else if (knownPanel(rawHash)) {
      activate(rawHash, { updateHash: false });
    }
  }

  window.addEventListener('hashchange', () => {
    const key = decodeURIComponent(location.hash.slice(1)) || 'overview';
    if (key.startsWith('comprehensive-')) {
      activate('comprehensive', { updateHash: false });
      document.getElementById(key)?.scrollIntoView({ block: 'start' });
    } else if (key === 'overview' || knownPanel(key)) {
      activate(key, { updateHash: false });
    }
  });

  async function postState(filePath: string, state: SubtaskState) {
    const res = await fetch('/__editor/subtask-toggle', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ filePath, state }),
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
  }

  function setStateOn(el: HTMLElement | null, state: SubtaskState) {
    if (!el) return;
    el.dataset.state = state;
    el.className = el.className.replace(/\bstate-(open|review|closed|cancelled)\b/g, '').trim() + ` state-${state}`;
  }

  function applySubtaskState(slug: string, state: SubtaskState) {
    const isDone = TERMINAL.includes(state);

    // Overview list item
    const overviewItem = document.querySelector<HTMLElement>(
      `.issue-overview-subtasks__item[data-subtask-slug="${CSS.escape(slug)}"]`,
    );
    setStateOn(overviewItem, state);
    const overviewBtn = overviewItem?.querySelector<HTMLElement>('.issue-overview-subtasks__state');
    if (overviewBtn) {
      overviewBtn.dataset.state = state;
      overviewBtn.innerHTML = ICONS[state];
    }

    // Comprehensive list item
    const compItem = document.querySelector<HTMLElement>(
      `.issue-comprehensive__item[data-subtask-slug="${CSS.escape(slug)}"]`,
    );
    setStateOn(compItem, state);
    const compBtn = compItem?.querySelector<HTMLElement>('.issue-comprehensive__state');
    if (compBtn) {
      compBtn.dataset.state = state;
      compBtn.innerHTML = ICONS[state];
    }
    const compPill = compItem?.querySelector<HTMLElement>('.issue-comprehensive__pill');
    if (compPill) compPill.textContent = state;

    // Subtask center page
    const page = document.querySelector<HTMLElement>(
      `.issue-subtask-page[data-subtask-slug="${CSS.escape(slug)}"]`,
    );
    if (page) {
      page.dataset.state = state;
      const pill = page.querySelector<HTMLElement>('[data-state-pill]');
      if (pill) pill.textContent = state;
    }

    // Sidebar button
    const sideBtn = document.querySelector<HTMLElement>(
      `.issue-sidebar__item[data-subtask-slug="${CSS.escape(slug)}"]`,
    );
    if (sideBtn) {
      sideBtn.dataset.state = state;
      sideBtn.classList.toggle('is-done', isDone);
      const icon = sideBtn.querySelector<HTMLElement>('[data-state-icon]');
      if (icon) icon.innerHTML = ICONS[state];
    }

    // Meta-index link (subtask index on Comprehensive)
    const indexLink = document.querySelector<HTMLElement>(
      `.issue-meta-index__link[data-subtask-slug="${CSS.escape(slug)}"]`,
    );
    setStateOn(indexLink, state);
    const indexIcon = indexLink?.querySelector<HTMLElement>('[data-state-icon]');
    if (indexIcon) indexIcon.innerHTML = ICONS[state];

    updateOverviewProgress();
    updateSidebarSubtasksCount();
    updateComprehensiveTabCounts();
    applyComprehensiveTabFilter();
  }

  function updateOverviewProgress() {
    const items = document.querySelectorAll<HTMLElement>('.issue-overview-subtasks__item');
    if (!items.length) return;
    let closed = 0, cancelled = 0, review = 0;
    items.forEach((i) => {
      const s = i.dataset.state as SubtaskState;
      if (s === 'closed') closed++;
      else if (s === 'cancelled') cancelled++;
      else if (s === 'review') review++;
    });
    const done = closed + cancelled;
    const total = items.length;
    const count = document.getElementById('overview-subtasks-count');
    if (count) count.textContent = `${done} / ${total}`;
    const bar = document.getElementById('overview-subtasks-bar');
    if (bar) {
      const pct = (n: number) => `${total ? (n / total) * 100 : 0}%`;
      const segs = bar.querySelectorAll<HTMLElement>('.issue-overview-subtasks__seg');
      if (segs[0]) segs[0].style.width = pct(closed);
      if (segs[1]) segs[1].style.width = pct(cancelled);
      if (segs[2]) segs[2].style.width = pct(review);
    }
  }

  function updateComprehensiveTabCounts() {
    const items = document.querySelectorAll<HTMLElement>('.issue-comprehensive__item');
    const counts: Record<string, number> = { open: 0, review: 0, closed: 0, cancelled: 0 };
    items.forEach((i) => {
      const s = i.dataset.state || '';
      if (s in counts) counts[s]++;
    });
    const total = items.length;
    const set = (key: string, n: number) => {
      const el = document.querySelector<HTMLElement>(`[data-comprehensive-tab="${key}"] .issue-comprehensive__tab-count`);
      if (el) el.textContent = String(n);
    };
    set('open', counts.open);
    set('review', counts.review);
    set('closed', counts.closed);
    set('cancelled', counts.cancelled);
    set('all', total);
  }

  function updateSidebarSubtasksCount() {
    const items = document.querySelectorAll<HTMLElement>('.issue-sidebar__item.is-subtask');
    if (!items.length) return;
    const done = Array.from(items).filter((i) => TERMINAL.includes(i.dataset.state as SubtaskState)).length;
    const review = Array.from(items).filter((i) => i.dataset.state === 'review').length;
    const heading = document.getElementById('sidebar-subtasks-count');
    if (heading) {
      heading.textContent = `${done}/${items.length}`;
      if (review > 0) {
        const dot = document.createElement('span');
        dot.className = 'issue-sidebar__review-dot';
        dot.setAttribute('aria-hidden', 'true');
        dot.title = `${review} awaiting review`;
        heading.appendChild(dot);
      }
    }
  }

  async function handleStateChange(slug: string, filePath: string, nextState: SubtaskState, prevState: SubtaskState) {
    applySubtaskState(slug, nextState);
    try {
      await postState(filePath, nextState);
    } catch (err) {
      console.error('[issues] subtask state change failed', err);
      applySubtaskState(slug, prevState);
    }
  }

  function wireStateButton(selector: string, itemSelector: string) {
    document.querySelectorAll<HTMLElement>(selector).forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const item = btn.closest<HTMLElement>(itemSelector);
        if (!item) return;
        const prev = (btn.dataset.state || 'open') as SubtaskState;
        const next = CYCLE[(CYCLE.indexOf(prev) + 1) % CYCLE.length];
        handleStateChange(item.dataset.subtaskSlug!, item.dataset.file!, next, prev);
      });
    });
  }
  wireStateButton('.issue-overview-subtasks__state', '.issue-overview-subtasks__item');
  wireStateButton('.issue-comprehensive__state', '.issue-comprehensive__item');

  // Expand/collapse for clippable comprehensive items (>150 words)
  document.querySelectorAll<HTMLElement>('[data-comprehensive-expand]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest<HTMLElement>('.issue-comprehensive__item');
      if (!item) return;
      const clipped = item.classList.toggle('is-clipped');
      btn.setAttribute('aria-expanded', clipped ? 'false' : 'true');
      btn.setAttribute('aria-label', clipped ? 'Expand subtask' : 'Collapse subtask');
    });
  });

  // Comprehensive filter tabs (Open / Review / Closed / Cancelled / All)
  type CompTab = 'open' | 'review' | 'closed' | 'cancelled' | 'all';
  let currentCompTab: CompTab = 'review';
  function applyComprehensiveTabFilter() {
    document.querySelectorAll<HTMLElement>('.issue-comprehensive__item').forEach((i) => {
      const s = i.dataset.state as SubtaskState;
      i.style.display = currentCompTab === 'all' || currentCompTab === s ? '' : 'none';
    });
    document.querySelectorAll<HTMLElement>('.issue-meta-index__link').forEach((a) => {
      const s = a.dataset.state as SubtaskState;
      (a.parentElement as HTMLElement).style.display =
        currentCompTab === 'all' || currentCompTab === s ? '' : 'none';
    });
  }
  document.querySelectorAll<HTMLElement>('[data-comprehensive-tab]').forEach((btn) => {
    btn.addEventListener('click', () => {
      currentCompTab = btn.dataset.comprehensiveTab as CompTab;
      document.querySelectorAll<HTMLElement>('[data-comprehensive-tab]').forEach((b) => {
        b.classList.toggle('is-active', b === btn);
      });
      applyComprehensiveTabFilter();
    });
  });
  applyComprehensiveTabFilter();
</script>

