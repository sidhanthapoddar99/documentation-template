---
/**
 * IndexBody - Orchestrator for the issues list page.
 * Component-specific UI + styles live under parts/index/ and scripts/index/;
 * page-frame styles live in styles/index.css.
 */
import { loadIssues } from '@loaders/issues';
import './styles/index.css';
import ViewToggle from './parts/index/ViewToggle.astro';
import FilterBar from './parts/index/FilterBar.astro';
import PresetStrip from './parts/index/PresetStrip.astro';
import StateTabs from './parts/index/StateTabs.astro';
import IssuesCards from './parts/index/IssuesCards.astro';
import IssuesTable from './parts/index/IssuesTable.astro';
import Pagination from './parts/index/Pagination.astro';

interface Props {
  dataPath: string;
  baseUrl: string;
}

const { dataPath, baseUrl } = Astro.props;
const { vocabulary, rootDraft, issues } = await loadIssues(dataPath);

const FILTER_FIELDS = ['priority', 'component', 'milestone', 'labels'] as const;
const filterGroups = FILTER_FIELDS
  .filter((f) => vocabulary.fields?.[f]?.values?.length)
  .map((f) => ({
    key: f,
    label: f,
    values: vocabulary.fields[f].values,
    colors: vocabulary.fields[f].colors || {},
  }));

function searchBlob(issue: typeof issues[number]): string {
  return [issue.id, issue.meta.title, issue.meta.description || '']
    .join(' ')
    .toLowerCase();
}

const TODAY = new Date().toISOString().slice(0, 10);
const CLOSED_STATUSES = new Set(['closed', 'cancelled']);
function isOverdue(meta: typeof issues[number]['meta']): boolean {
  if (!meta.due) return false;
  if (meta.due >= TODAY) return false;
  return !CLOSED_STATUSES.has(meta.status);
}

// Review tab covers two cases:
//   1. Issue explicitly in status=review
//   2. Issue still open but has at least one subtask in review — surface the
//      review debt to the human without forcing the issue status to flip.
function issueNeedsReview(issue: typeof issues[number]): boolean {
  if (issue.meta.status === 'review') return true;
  if (!CLOSED_STATUSES.has(issue.meta.status)) {
    return issue.subtasks.some((s) => s.state === 'review');
  }
  return false;
}
const reviewCount = issues.filter(issueNeedsReview).length;
const openCount = issues.filter((i) => !CLOSED_STATUSES.has(i.meta.status) && !issueNeedsReview(i)).length;
const closedCount = issues.filter((i) => i.meta.status === 'closed').length;
const cancelledCount = issues.filter((i) => i.meta.status === 'cancelled').length;

// Group-by only offers dimensions that actually have a vocabulary —
// otherwise there's nothing to group under. `status` intentionally
// excluded (state tabs already group by status).
const GROUP_CANDIDATES = ['component', 'milestone', 'priority'] as const;
const groupDimensions = GROUP_CANDIDATES.filter(
  (d) => vocabulary.fields?.[d]?.values?.length,
);
const groupOrderByField = Object.fromEntries(
  groupDimensions.map((d) => [d, vocabulary.fields[d].values]),
);

const presets = Array.isArray(vocabulary.views) ? vocabulary.views : [];

// Server-side config passed to the client script via a JSON script tag
const clientConfig = {
  priorityOrder: vocabulary.fields?.priority?.values ?? [],
  statusOrder: vocabulary.fields?.status?.values ?? [],
  colorsByField: Object.fromEntries(filterGroups.map((g) => [g.key, g.colors])),
  groupDimensions,
  groupOrderByField,
  presets,
};
---

<div class="issues-index">
  <header class="issues-index__header">
    <div class="issues-index__titlebar">
      <div>
        <h1 class="issues-index__title">{vocabulary.label || 'Issues'}</h1>
        <p class="issues-index__summary">
          <span id="issues-count">{issues.length}</span> of {issues.length} issue{issues.length === 1 ? '' : 's'}
          {rootDraft ? ' · dev-only tracker' : ''}
        </p>
      </div>
      <ViewToggle />
    </div>
  </header>

  <FilterBar filterGroups={filterGroups} groupDimensions={groupDimensions} />

  <PresetStrip presets={presets} />

  <StateTabs openCount={openCount} reviewCount={reviewCount} closedCount={closedCount} cancelledCount={cancelledCount} totalCount={issues.length} />

  {issues.length > 0 ? (
    <>
      <IssuesCards
        issues={issues}
        vocabulary={vocabulary}
        baseUrl={baseUrl}
        searchBlob={searchBlob}
        isOverdue={isOverdue}
      />
      <IssuesTable
        issues={issues}
        vocabulary={vocabulary}
        baseUrl={baseUrl}
        searchBlob={searchBlob}
        isOverdue={isOverdue}
      />
    </>
  ) : (
    <div class="issues-index__empty">
      <p>No issues found.</p>
    </div>
  )}

  <div class="issues-index__empty" id="issues-empty" hidden>
    <p>No issues match these filters. <a href="#" id="issues-reset">Clear filters</a>.</p>
  </div>

  <Pagination />
</div>

<script is:inline type="application/json" id="issues-config" set:html={JSON.stringify(clientConfig)} />

<script>
  import { initIssuesIndex } from './scripts/index/client';
  initIssuesIndex();
</script>

