---
import StatusBadge from './StatusBadge.astro';
import type { Issue, IssuesVocabulary } from '@loaders/issues';

interface Props {
  issue: Issue;
  vocabulary: IssuesVocabulary;
}

const { issue, vocabulary } = Astro.props;
const { meta } = issue;

function formatDate(value: string | null | undefined): string {
  if (!value) return '';
  const d = new Date(value);
  if (isNaN(d.getTime())) return value;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
}

const singleFields = [
  ['Status', 'status', meta.status],
  ['Priority', 'priority', meta.priority],
  ['Component', 'component', meta.component],
  ['Milestone', 'milestone', meta.milestone],
] as const;
---

<aside class="issue-meta-panel">
  <dl>
    <div class="issue-meta-panel__row">
      <dt>ID</dt>
      <dd><code class="issue-meta-panel__id">{issue.id}</code></dd>
    </div>

    {singleFields.map(([label, field, value]) => (
      <div class="issue-meta-panel__row">
        <dt>{label}</dt>
        <dd><StatusBadge field={field} value={value} vocabulary={vocabulary.fields} /></dd>
      </div>
    ))}

    <div class="issue-meta-panel__row">
      <dt>Labels</dt>
      <dd>
        {meta.labels.length > 0
          ? meta.labels.map((l) => <StatusBadge field="labels" value={l} vocabulary={vocabulary.fields} />)
          : <span class="issue-meta-panel__empty">—</span>}
      </dd>
    </div>

    <div class="issue-meta-panel__row">
      <dt>Assignees</dt>
      <dd>
        {meta.assignees.length > 0
          ? meta.assignees.join(', ')
          : <span class="issue-meta-panel__empty">—</span>}
      </dd>
    </div>

    <div class="issue-meta-panel__row">
      <dt>Author</dt>
      <dd>{meta.author || '—'}</dd>
    </div>

    <div class="issue-meta-panel__row">
      <dt>Created</dt>
      <dd>{formatDate(issue.created)}</dd>
    </div>

    <div class="issue-meta-panel__row">
      <dt>Updated</dt>
      <dd>{formatDate(meta.updated)}</dd>
    </div>

    <div class="issue-meta-panel__row">
      <dt>Due</dt>
      <dd>{meta.due ? formatDate(meta.due) : <span class="issue-meta-panel__empty">—</span>}</dd>
    </div>
  </dl>
</aside>

<style>
  .issue-meta-panel {
    border: 1px solid var(--color-border-default);
    border-radius: 6px;
    padding: 1rem;
    font-size: var(--ui-text-body);
  }
  .issue-meta-panel dl {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .issue-meta-panel__row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .issue-meta-panel__row dt {
    font-size: var(--ui-text-micro);
    color: var(--color-text-muted);
  }
  .issue-meta-panel__row dd {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: center;
  }
  .issue-meta-panel__empty {
    color: var(--color-text-muted);
  }
  .issue-meta-panel__id {
    font-family: var(--font-family-mono);
    font-size: var(--ui-text-micro);
    color: var(--color-text-primary);
    background: transparent;
    padding: 0;
    word-break: break-all;
  }
</style>
