# Environment Configuration Template
# Copy this to: docs/.env
# Paths are relative to documentation-template/ folder

# ============================================
# DIRECTORY PATHS
# ============================================

# Configuration files (site.yaml, navbar.yaml, footer.yaml)
CONFIG_DIR=../data/config

# User content (docs, blog, pages)
DATA_DIR=../data/data

# Static assets (logos, favicons, images)
ASSETS_DIR=../data/assets

# Custom themes (optional)
THEMES_DIR=../data/themes

# ============================================
# SERVER SETTINGS
# ============================================

# Development server port
PORT=3088

# Host configuration (true = allow all hosts)
HOST=true
