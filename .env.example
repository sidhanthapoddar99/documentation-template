# ============================================
# DIRECTORY PATHS
# ============================================
# Bootstrap: points to the config directory containing site.yaml.
# All other paths (data, assets, themes) are defined in site.yaml's paths: section.
#
# This .env.example is for DOGFOOD MODE — the framework repo IS the project,
# content lives under default-docs/. For CONSUMER MODE (framework cloned as a
# subfolder of your own project), use CONFIG_DIR=../config to reach back up
# to your content. See default-docs/data/user-guide/10_configuration/02_env.md
# for both modes side by side.
CONFIG_DIR=./default-docs/config

# Optional: External layout directory (mirrors src/layouts/ structure minus BaseLayout).
# External layouts merge with built-in; same-name styles override built-in.
# Dogfood mode example:
# LAYOUT_EXT_DIR=./default-docs/layouts
# Consumer mode example:
# LAYOUT_EXT_DIR=../layouts

# ============================================
# SERVER SETTINGS
# ============================================

PORT=3088
HOST=true
