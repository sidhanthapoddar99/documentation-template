# ============================================
# DIRECTORY PATHS
# ============================================
# Bootstrap: points to the config directory containing site.yaml.
# All other paths (data, assets, themes) are defined in site.yaml's paths: section.
#
# NOTE: this .env.example is provided for reference only. In the documented
# consumer-mode flow, .env actually lives INSIDE the framework folder
# (`<user-project>/documentation-template/.env`) and uses CONFIG_DIR=../config
# to reach back UP to your config/ at the project root. The values shown
# below (CONFIG_DIR=./config) only make sense if you're keeping .env at the
# user-project root level — which the init flow does NOT do.
#
# Recommended (consumer mode), inside the framework folder:
#   CONFIG_DIR=../config
#
# Reference value if you're running this template standalone for any reason:
CONFIG_DIR=./config

# Optional: External layout directory (mirrors src/layouts/ structure minus BaseLayout).
# External layouts merge with built-in; same-name styles override built-in.
# Consumer mode: LAYOUT_EXT_DIR=../layouts
# Standalone reference: LAYOUT_EXT_DIR=./layouts

# ============================================
# SERVER SETTINGS
# ============================================

PORT=3088
HOST=true
