{
  "label": "Issues",
  "fields": {
    "status": {
      "values": ["open", "review", "closed", "cancelled"],
      "colors": {
        "open": "#888888",
        "review": "#f0c674",
        "closed": "#7ec699",
        "cancelled": "#666666"
      }
    },
    "priority": {
      "values": ["low", "medium", "high", "urgent"],
      "colors": {
        "low": "#7aa2f7",
        "medium": "#f0c674",
        "high": "#e5a663",
        "urgent": "#e06c75"
      }
    },
    "component": {
      "values": ["docs", "site", "infra"]
    },
    "milestone": {
      "values": ["backlog", "next", "later"]
    },
    "labels": {
      "values": ["bug", "feature", "task", "docs", "discussion"]
    }
  },
  "authors": ["you"],
  "views": [
    { "name": "Open", "filters": { "status": ["open"] } },
    { "name": "In review", "filters": { "status": ["review"] } },
    { "name": "By milestone", "group": "milestone" }
  ]
}
